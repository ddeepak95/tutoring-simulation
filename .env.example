# Provider API keys (set whichever providers your selected models need)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Gemini goes through Vertex AI, authenticated with Application Default Credentials
# (no API key). One-time setup, per person:
#   gcloud auth application-default login \
#     --impersonate-service-account=model-access@deepak-experiments.iam.gserviceaccount.com
# "global" is required: the Gemini 3.x models are not served from regional endpoints.
VERTEXAI_PROJECT=deepak-experiments
VERTEXAI_LOCATION=global

# Optional defaults when run_set entry omits model ids
TUTORING_TEACHER_MODEL=
TUTORING_STUDENT_MODEL=
